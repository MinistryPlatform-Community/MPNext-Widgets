{
  "name": "mpnext-widgets",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.9"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev:next": "next dev",
    "dev:sdk": "pnpm --filter @mpnext/embed-sdk dev",
    "dev": "concurrently -n next,widget -c blue,green \"next dev\" \"pnpm --filter @mpnext/embed-sdk demo\"",
    "test:widget": "concurrently -n next,widget -c blue,green \"next dev\" \"pnpm --filter @mpnext/embed-sdk demo\"",
    "build": "pnpm build:sdk && next build",
    "build:web": "next build",
    "build:sdk": "pnpm --filter @mpnext/embed-sdk build && node scripts/hash-sdk.js && node scripts/copy-sdk.js",
    "start": "next start",
    "lint": "eslint .",
    "mp:generate": "tsx src/lib/providers/ministry-platform/scripts/generate-types.ts",
    "mp:generate:models": "tsx src/lib/providers/ministry-platform/scripts/generate-types.ts -o src/lib/providers/ministry-platform/models --zod --clean",
    "dev:demo": "pnpm build:sdk && next dev",
    "setup": "tsx scripts/setup.ts",
    "setup:check": "tsx scripts/setup.ts --check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:widget": "playwright test --project=widget"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "better-auth": "^1.6.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.22.3",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "cookie": ">=0.7.0",
      "defu": ">=6.1.7",
      "minimatch@3>brace-expansion": "1.1.15",
      "postcss": ">=8.5.10",
      "kysely": "^0.28.17"
    }
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.5.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.5.0",
    "chalk": "^5.6.2",
    "concurrently": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^29.0.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
