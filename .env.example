# NextAuth Provider Configuration (OIDC)
OIDC_PROVIDER_NAME="MinistryPlatform"
OIDC_CLIENT_ID=your-oidc-client-id
OIDC_CLIENT_SECRET=your-oidc-client-secret
OIDC_WELL_KNOWN_URL=https://your-mp-instance.com/ministryplatformapi/oauth/.well-known/openid-configuration
OIDC_SCOPE=openid profile email offline_access http://www.thinkministry.com/dataplatform/scopes/all

# NextAuth
# Generate via: npx auth secret
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_DEBUG=false

# MinistryPlatform API Configuration
MINISTRY_PLATFORM_CLIENT_ID=your-client-id
MINISTRY_PLATFORM_CLIENT_SECRET=your-client-secret
MINISTRY_PLATFORM_BASE_URL=https://your-mp-instance.com/ministryplatformapi

# NEXT Public Keys
NEXT_PUBLIC_MINISTRY_PLATFORM_FILE_URL=https://your-mp-instance.com/ministryplatformapi/files
NEXT_PUBLIC_APP_NAME=MPNext-Components

# Embed Widget Settings
EMBED_JWT_SECRET=your-jwt-secret-for-widget-auth
EMBED_INIT_TOKEN_SECRET=your-init-token-secret